# CIBER_APP Environment Variables
# Copy this file to .env and configure accordingly.

# Allow specific origins for CORS (comma-separated). Use * for development only.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Path to SQLite Database
DB_PATH=threat_center.db

# Logging Level (INFO, DEBUG, ERROR)
LOG_LEVEL=INFO
